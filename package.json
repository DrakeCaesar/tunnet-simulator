{
  "name": "tunnet-sim",
  "version": "0.1.0",
  "private": true,
  "description": "Tunnet topology and synchronized tick simulator",
  "type": "module",
  "scripts": {
    "dev": "vite --config web/vite.config.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "data:normalize": "tsx src/normalize-endpoint-data.ts",
    "data:missing-ranges": "tsx src/report-missing-address-ranges.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts",
    "bench:layout-url": "tsx src/benchmark-layout-url-encodings.ts",
    "sched:compare": "tsx src/compare-scheduler.ts",
    "sched:sequence": "tsx src/export-message-sequence.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cli-table3": "^0.6.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "brotli-ts": "^0.0.7",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9"
  }
}
