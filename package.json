{
  "name": "tunnet-sim",
  "version": "0.1.0",
  "private": true,
  "description": "Tunnet topology and synchronized tick simulator",
  "type": "module",
  "scripts": {
    "dev": "vite --config web/vite.config.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "data:normalize": "tsx src/analysis/normalize-endpoint-data.ts",
    "data:missing-ranges": "tsx src/analysis/report-missing-address-ranges.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts",
    "bench:layout-url": "tsx src/benchmark-layout-url-encodings.ts",
    "sched:compare": "tsx src/analysis/compare-scheduler.ts",
    "sched:sequence": "tsx src/analysis/export-message-sequence.ts",
    "compare:edges": "tsx src/analysis/compare-endpoint-edges.ts",
    "compare:edge-ttls": "tsx src/analysis/compare-edge-ttls.ts",
    "compare:edges:scan": "tsx src/analysis/compare-endpoint-edges.ts scan 1000 0 8 0 8",
    "extract:exe-strings": "python analysis/scripts/extract-tunnet-rdata-strings.py",
    "extract:packet-pools": "python analysis/scripts/extract-packet-string-pools.py",
    "sort:rdata-strings": "python analysis/scripts/sort-tunnet-rdata-jsonl.py"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cli-table3": "^0.6.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "brotli-ts": "^0.0.7",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9"
  }
}
